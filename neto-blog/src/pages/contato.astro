---
import Layout from "../layouts/layout.astro";
---

<Layout>
  <section class="flex flex-col items-center gap-8 py-20 px-4">
    <div class="text-center">
      <h1 class="text-4xl font-bold text-destaque mb-2"> >_Contato:</h1>
      <p class="text-texto">
        Entre em contato comigo através dos seguintes canais
      </p>
    </div>

    <ul
      class="grid grid-cols-2 md:grid-cols-3 gap-4 w-full max-w-xl list-none p-0 m-0"
    >
      <!-- Email -->
      <li>
        <a
          href="mailto:adalbertoneto13@yahoo.com"
          class="flex flex-col items-center gap-3 p-6 rounded-xl border border-items bg-items/30 backdrop-blur-sm hover:border-destaque hover:bg-items/60 hover:shadow-[0_0_20px_rgba(0,255,65,0.15)] transition-all duration-300 group"
        >
          <svg
            class="w-7 h-7 text-texto group-hover:text-destaque transition-colors duration-300"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <rect width="20" height="16" x="2" y="4" rx="2"></rect>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
          </svg>
          <span
            class="text-xs font-semibold tracking-widest uppercase text-texto group-hover:text-destaque transition-colors duration-300"
            >Email</span
          >
        </a>
      </li>

      <!-- LinkedIn -->
      <li>
        <a
          href="www.linkedin.com/in/adalberto-neto-c13"
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-center gap-3 p-6 rounded-xl border border-items bg-items/30 backdrop-blur-sm hover:border-destaque hover:bg-items/60 hover:shadow-[0_0_20px_rgba(0,255,65,0.15)] transition-all duration-300 group"
        >
          <svg
            class="w-7 h-7 text-texto group-hover:text-destaque transition-colors duration-300"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
            ></path>
            <rect width="4" height="12" x="2" y="9"></rect>
            <circle cx="4" cy="4" r="2"></circle>
          </svg>
          <span
            class="text-xs font-semibold tracking-widest uppercase text-texto group-hover:text-destaque transition-colors duration-300"
            >LinkedIn</span
          >
        </a>
      </li>

      <!-- GitHub -->
      <li>
        <a
          href="https://github.com/c13neto"
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-center gap-3 p-6 rounded-xl border border-items bg-items/30 backdrop-blur-sm hover:border-destaque hover:bg-items/60 hover:shadow-[0_0_20px_rgba(0,255,65,0.15)] transition-all duration-300 group"
        >
          <svg
            class="w-7 h-7 text-texto group-hover:text-destaque transition-colors duration-300"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
            ></path>
            <path d="M9 18c-4.51 2-5-2-7-2"></path>
          </svg>
          <span
            class="text-xs font-semibold tracking-widest uppercase text-texto group-hover:text-destaque transition-colors duration-300"
            >GitHub</span
          >
        </a>
      </li>

      <!-- Instagram -->
      <li>
        <a
          href="https://www.instagram.com/netoc_13/"
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-center gap-3 p-6 rounded-xl border border-items bg-items/30 backdrop-blur-sm hover:border-destaque hover:bg-items/60 hover:shadow-[0_0_20px_rgba(0,255,65,0.15)] transition-all duration-300 group"
        >
          <svg
            class="w-7 h-7 text-texto group-hover:text-destaque transition-colors duration-300"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
          </svg>
          <span
            class="text-xs font-semibold tracking-widest uppercase text-texto group-hover:text-destaque transition-colors duration-300"
            >Instagram</span
          >
        </a>
      </li>

      <!-- Linktree -->
      <li>
        <a
          href="https://www.linktr.ee/neto13c"
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-center gap-3 p-6 rounded-xl border border-items bg-items/30 backdrop-blur-sm hover:border-destaque hover:bg-items/60 hover:shadow-[0_0_20px_rgba(0,255,65,0.15)] transition-all duration-300 group"
        >
          <!-- Linktree: ícone de árvore/links -->
          <svg
            class="w-7 h-7 text-texto group-hover:text-destaque transition-colors duration-300"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path d="M12 2v20"></path>
            <path d="M6 7l6-5 6 5"></path>
            <path d="M6 13l6-5 6 5"></path>
          </svg>
          <span
            class="text-xs font-semibold tracking-widest uppercase text-texto group-hover:text-destaque transition-colors duration-300"
            >Linktree</span
          >
        </a>
      </li>
    </ul>
  </section>

  <!-- DIVISOR -->
  <div class="w-full max-w-xl mx-auto border-t border-items/50"></div>

  <!-- SUPORTE -->
  <section class="flex flex-col items-center gap-8 py-20 px-4">
    <div class="text-center">
      <h1 class="text-4xl font-bold text-destaque mb-2">>_Suporte:</h1>
      <p class="text-texto">
        Se o meu trabalho te ajudou, considere me apoiar
      </p>
    </div>

    <ul
      class="grid grid-cols-1 md:grid-cols-3 gap-4 w-full max-w-xl list-none p-0 m-0"
    >
      <!-- Pix -->
      <li>
        <button
          id="btn-pix"
          data-copy="adalbertoneto13@yahoo.com"
          class="w-full cursor-pointer flex flex-col items-center gap-3 p-6 rounded-xl border border-items bg-items/30 backdrop-blur-sm hover:border-destaque hover:bg-items/60 hover:shadow-[0_0_20px_rgba(0,255,65,0.15)] transition-all duration-300 group"
        >
          <svg
            class="w-7 h-7 text-texto group-hover:text-destaque transition-colors duration-300"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              d="M12 2 8.5 8.5 2 9.27l5 4.87L5.82 21 12 17.77 18.18 21 17 14.14l5-4.87-6.5-.77L12 2z"
            ></path>
          </svg>

          <span
            id="texto-pix"
            class="text-xs font-semibold tracking-widest uppercase text-texto group-hover:text-destaque transition-colors duration-300"
          >
            Pix
          </span>

          <span
            class="text-[10px] text-texto/60 group-hover:text-destaque/70 transition-colors duration-300 text-center leading-tight break-all"
          >
            adalbertoneto13@yahoo.com
          </span>
        </button>
      </li>

      <!-- PayPal -->
      <li>
        <a
          href="https://www.paypal.com/paypalme/adalbertoneto13"
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-center gap-3 p-6 rounded-xl border border-items bg-items/30 backdrop-blur-sm hover:border-destaque hover:bg-items/60 hover:shadow-[0_0_20px_rgba(0,255,65,0.15)] transition-all duration-300 group"
        >
          <svg
            class="w-7 h-7 text-texto group-hover:text-destaque transition-colors duration-300"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path d="M6.375 21H4l1.5-9h4.5c3 0 5-1.5 5-4.5S12 3 9 3H4.5L3 12"
            ></path>
            <path d="M10.875 21H8.5l1.5-9h4.5c3 0 5-1.5 5-4.5"></path>
          </svg>
          <span
            class="text-xs font-semibold tracking-widest uppercase text-texto group-hover:text-destaque transition-colors duration-300"
            >PayPal</span
          >
        </a>
      </li>

      <!-- Ko-fi -->
      <li>
        <a
          href="https://www.ko-fi.com/adalbertoneto1309"
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-center gap-3 p-6 rounded-xl border border-items bg-items/30 backdrop-blur-sm hover:border-destaque hover:bg-items/60 hover:shadow-[0_0_20px_rgba(0,255,65,0.15)] transition-all duration-300 group"
        >
          <svg
            class="w-7 h-7 text-texto group-hover:text-destaque transition-colors duration-300"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path d="M17 8h1a4 4 0 1 1 0 8h-1"></path>
            <path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"></path>
            <line x1="6" x2="6" y1="2" y2="4"></line>
            <line x1="10" x2="10" y1="2" y2="4"></line>
            <line x1="14" x2="14" y1="2" y2="4"></line>
          </svg>
          <span
            class="text-xs font-semibold tracking-widest uppercase text-texto group-hover:text-destaque transition-colors duration-300"
            >Ko-fi</span
          >
        </a>
      </li>
    </ul>
  </section>
  <script>
  const btnPix = document.getElementById('btn-pix');
  const textoPix = document.getElementById('texto-pix');
  
  // Salva a palavra "Pix" original na memória
  const textoOriginal = textoPix?.innerText;

  btnPix?.addEventListener('click', async () => {
    const chavePix = btnPix.getAttribute('data-copy');
    
    if (chavePix) {
      try {
        // Dispara a cópia para a área de transferência do sistema
        await navigator.clipboard.writeText(chavePix);
        
        // Efeito de sucesso: Muda o texto para modo Terminal
        if (textoPix) {
          textoPix.innerText = ">_ COPIADO!";
        }

        // Reseta o botão para o estado original após 2 segundos
        setTimeout(() => {
          if (textoPix && textoOriginal) {
            textoPix.innerText = textoOriginal;
          }
        }, 2000);
        
      } catch (err) {
        console.error('Falha na operação de cópia:', err);
      }
    }
  });
</script>
</Layout>
