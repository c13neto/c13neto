---
const { pathname } = Astro.url;

const links = [
  {
    href: "/c13neto/",
    label: "Home",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>',
  },
  {
    href: "/c13neto/blog",
    label: "Blog",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>',
  },
  {
    href: "/c13neto/stack",
    label: "Stack",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
    disable: true,
  },
  {
    href: "/c13neto/sobre",
    label: "Sobre Mim",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>',
  },
  {
    href: "/c13neto/contato",
    label: "Contato",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>',
  },
];
---

<nav>
  <ul
    class="flex flex-row gap-1.5 text-texto h-[5dvh] items-center text-[9px] md:text-md md:justify-evenly md:text-lg justify-between pl-1"
  >
    {
      links.map((link) => {
        const isActive = pathname === link.href || pathname === link.href + "/";
        return (
          <li>
            {link.disable ? (
              <span class="flex items-center gap-1 opacity-40 cursor-not-allowed">
                <span set:html={link.icon} />
                <span>{link.label}</span>
              </span>
            ) : (
              <a
                href={link.href}
                class={`flex items-center gap-1 ${isActive ? "active" : ""}`}
              >
                <span set:html={link.icon} />
                <span>{link.label}</span>
              </a>
            )}
          </li>
        );
      })
    }
  </ul>
</nav>
