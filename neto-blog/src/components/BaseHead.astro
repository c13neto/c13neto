---
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import "../styles/global.css";
---
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>{SITE_TITLE}</title>
	<meta name="description" content={SITE_DESCRIPTION} />
	<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text x='50%' y='55%' dominant-baseline='middle' text-anchor='middle' font-size='95' fill='%2300FF41' font-family='Arial, sans-serif' font-weight='900'>( )</text></svg>" />
</head>